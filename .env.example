# Copy this file to .env for local configuration.
PORT=3000
HOST=127.0.0.1
DATA_DIR=./data
COOKIE_SECURE=false
SESSION_HOURS=8
CLEANUP_INTERVAL_MINUTES=15
CLAMSCAN_PATH=clamscan
CLAMSCAN_TIMEOUT_MS=30000

# Unsafe local-development bypass. Keep false for hotel use.
ALLOW_UNSAFE_ANTIVIRUS_BYPASS=false

# Test-only values: normal, mock-clean, mock-infected, mock-error, mock-timeout
ANTIVIRUS_MODE=normal

# Cloud backend. Keep the secret key on the server only; never put it in public JS.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=guest-documents
